{
  "entityTypes": [
    {
      "type": "configuration/entityTypes/Person",
      "functions": [
        {
          "name": "Validate First Name",
          "label": "",
          "description": "Validate First Name",
          "expression": "not regexp(attributes.FirstName.value, '^[ A-Za-z \u2019-]+$') or missing(attributes.FirstName.value)",
          "action": "WARNING",
          "validationEvent": "ALL",
          "message": "Enter valid First Name",
          "createdBy": "platform-management-service-user",
          "createdTime": "1721938886832",
          "updatedBy": "platform-management-service-user",
          "updatedTime": "1721938886832",
          "status": "ACTIVE",
          "attribute": "configuration/entityTypes/Person/attributes/FirstName"
        },
        {
          "name": "Validate Last Name",
          "label": "",
          "description": "Validate Last Name",
