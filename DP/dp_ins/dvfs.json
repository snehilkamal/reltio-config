      "type": "configuration/entityTypes/Structure",
      "functions": [
        {
          "name": "Inconsistent Composite Risk Level",
          "label": "",
          "description": "Inconsistency in composite risk level check",
          "expression": "equals(attributes.FloodRiskProbability.value, 'High') and equals(attributes.EarthquakeRiskProbability.value, 'High') and not(equals(attributes.CompositeRiskLevel.value, 'High'))",
          "action": "WARNING",
          "validationEvent": "ALL",
          "message": "Inconsistent Composite Risk Level",
          "createdBy": "platform-management-service-user",
          "createdTime": "1721938654962",
          "updatedBy": "platform-management-service-user",
          "updatedTime": "1721938654962",
          "status": "ACTIVE",
          "attribute": "configuration/entityTypes/Structure/attributes/CompositeRiskLevel"
        },
        {
          "name": "Missing CLIP Identifier",
