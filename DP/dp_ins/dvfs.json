    {
      "type": "configuration/entityTypes/Organization",
      "functions": [
        {
          "name": "InvalidDunsNumberFormat",
          "label": "",
          "description": "Invalid Duns Number Format",
          "expression": "exists(attributes.DUNSNumber.value) and not(regexp(attributes.DUNSNumber.value, '[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]'))",
          "action": "WARNING",
          "validationEvent": "ALL",
          "message": "Invalid Duns Number Format",
          "createdBy": "platform-management-service-user",
          "createdTime": "1721938654702",
          "updatedBy": "platform-management-service-user",
          "updatedTime": "1721938654702",
          "status": "ACTIVE",
          "attribute": "configuration/entityTypes/Organization/attributes/DUNSNumber"
        },
        {
          "name": "SuspiciouslyShortName",
          "label": "",
          "description": "Short Name (1-3 characters)",
          "expression": "regexp(attributes.Name.value, '^.{1,3}$')",
          "action": "WARNING",
