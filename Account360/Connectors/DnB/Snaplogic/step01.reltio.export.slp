              {
                "queryParamValue": {
                  "expression": true,
                  "value": "\"(equals(type, 'configuration/entityTypes/Organization') and (missing(attributes.DUNSNumber)  or equals(attributes.ManualVerificationFlag,'true') or lt(attributes.VendorVerificationDate, \" + Math.ceil(Date.now().minusDays(_dnbVerificationAgeGreaterThan).getTime()) + \")))   and (missing(attributes.DoNotEnrich) or equals(attributes.DoNotEnrich, 'false'))\""
                },
                "queryParam": {
                  "value": "filter"
                }
              },
              {
