      "purpose": {
        "value": "This pipeline exports organizations from Reltio tenant using async mode.\n\nSteps:\n1) Reltio API call for export entities.\n\nExpected result:\nAfter some time Reltio user will receive notification mail from Export service that data has been exported and can be downloaded. Next step will use this link."
      },
      "pipeline_doc_uri": {
        "value": null
      },
      "label": {
        "value": "step01.reltio.export"
